---
import { availableWikis } from "fandomscraper";
import WikiasCol from "./WikiasCol.astro";
---
<div class="image-grid">
    {availableWikis.map(wiki => (
        <WikiasCol title={wiki} />
    ))}
</div>
<style>

.image-grid {
    margin-top: 50px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
}

</style>