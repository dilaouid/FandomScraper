---
export interface Props {
	title: string;
}

const { title } = Astro.props;
---
<div class="main-container">
    <div class="poster-container">
        <a href={`/${title}`}>
            <img class="poster" src={`/assets/img/animes/${title}.jpg`} alt={title + " poster"} />
        </a>
    </div>
</div>
    
<script type="module">
    import "/assets/js/hoverCard.js"
</script>

<style>
* {
	box-sizing: border-box;
	padding: 0;
	margin: 0;
}

.main-container {
	display: flex;
	justify-content: center;
	width: 270px;
    margin-bottom: -80px;
    transition: transform 0.5s ease;
}

.poster-container {
    width: 230px;
    margin-bottom: 100px;
}

.poster-container:hover .poster {
    transform: scale(1.1);
    filter: grayscale(0%);
    opacity: 1;
}

.poster {
    width: 100%;
    filter: grayscale(80%);  /* Initial black and white */
    box-shadow: 0 5px 20px 3px rgba(0, 0, 0, 0.6);
    border-radius: 30px 30px 0 0;
    transition: transform .5s ease-in-out, filter .2s ease-in-out;
    opacity: .5;
}
</style>